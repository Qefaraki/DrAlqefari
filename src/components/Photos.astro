---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- Featured: Wozniak — photo first (left in EN, right in AR) -->
<section class="border-t border-border/60">
  <div class="grid grid-cols-1 md:grid-cols-2 md:items-stretch md:min-h-[500px]">
    <!-- Image -->
    <div class="bg-bg-warm overflow-hidden md:relative order-1">
      <img
        src="/images/photos/with-wozniak.jpg"
        alt={t('photos.wozniak.caption')}
        class="w-full h-auto md:absolute md:inset-0 md:h-full md:object-cover"
        loading="lazy"
      />
    </div>

    <!-- Text -->
    <div class="order-2 flex items-center px-6 py-12 md:py-0 md:ps-12 md:pe-12 lg:ps-16 lg:pe-20">
      <div>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold text-fg leading-[1.15] mb-4">
          {t('photos.wozniak.caption')}
        </h3>
        <p class="text-muted text-base md:text-lg">{t('photos.wozniak.note')}</p>
      </div>
    </div>
  </div>
</section>
