---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);

const fullPagePath = lang === 'ar' ? '/leaders/' : '/en/leaders/';

const featured = [
  {
    name: t('leaders.gates.name'),
    role: t('leaders.gates.role'),
    quote: t('leaders.gates.quote'),
    source: t('leaders.gates.source'),
    image: '/images/leaders/bill-gates.webp',
  },
  {
    name: t('leaders.schmidt.name'),
    role: t('leaders.schmidt.role'),
    quote: t('leaders.schmidt.quote'),
    source: t('leaders.schmidt.source'),
    image: '/images/leaders/eric-schmidt.webp',
  },
  {
    name: t('leaders.gawande.name'),
    role: t('leaders.gawande.role'),
    quote: t('leaders.gawande.quote'),
    source: t('leaders.gawande.source'),
    image: '/images/leaders/atul-gawande.webp',
  },
];
---

<section id="leaders" class="border-t border-border/60">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <div class="mb-12 reveal">
      <h2 class="text-xl md:text-2xl font-bold text-fg mb-3">{t('leaders.title')}</h2>
      <p class="text-muted text-[15px] leading-[1.8] max-w-2xl">{t('leaders.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 reveal">
      {featured.map((item) => (
        <article class="flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <img
              src={item.image}
              alt={item.name}
              width="48"
              height="48"
              class="w-12 h-12 rounded-full object-cover bg-bg-warm border border-border/40 shrink-0"
              loading="lazy"
            />
            <div class="min-w-0">
              <p class="font-bold text-fg text-[14px] leading-tight">{item.name}</p>
              <p class="text-muted text-[12px] leading-tight mt-0.5 truncate">{item.role}</p>
            </div>
          </div>
          <blockquote class="text-fg-light leading-[1.85] text-[14px] mb-3 border-s-2 border-accent/30 ps-3">
            {item.quote}
          </blockquote>
          {item.source && (
            <p class="text-muted text-[11px] mt-auto pt-2">{item.source}</p>
          )}
        </article>
      ))}
    </div>

    <div class="mt-12 reveal">
      <a
        href={fullPagePath}
        class="inline-flex items-center gap-2 text-[14px] font-semibold text-primary hover:text-primary-light transition-colors"
      >
        {t('leaders.readMore')}
        <span class="rtl:rotate-180">→</span>
      </a>
    </div>
  </div>
</section>
