---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);

const fullPagePath = lang === 'ar' ? '/leaders/' : '/en/leaders/';

const featured = [
  {
    name: t('leaders.gates.name'),
    role: t('leaders.gates.role'),
    quote: t('leaders.gates.quote'),
    source: t('leaders.gates.source'),
    image: '/images/leaders/bill-gates.webp',
  },
  {
    name: t('leaders.schmidt.name'),
    role: t('leaders.schmidt.role'),
    quote: t('leaders.schmidt.quote'),
    source: t('leaders.schmidt.source'),
    image: '/images/leaders/eric-schmidt.webp',
  },
  {
    name: t('leaders.bezos.name'),
    role: t('leaders.bezos.role'),
    quote: t('leaders.bezos.quote'),
    source: t('leaders.bezos.source'),
    image: '/images/leaders/jeff-bezos.webp',
  },
];
---

<section id="leaders" class="border-t border-border/60">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <div class="mb-10 reveal">
      <h2 class="text-xl md:text-2xl font-bold text-fg mb-3">{t('leaders.title')}</h2>
      <p class="text-muted text-[15px] leading-[1.8] max-w-2xl">{t('leaders.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal">
      {featured.map((item) => (
        <a
          href={fullPagePath}
          class="group relative block rounded-2xl overflow-hidden bg-fg/90 min-h-[420px] md:min-h-[460px] flex flex-col justify-end shadow-lg shadow-fg/10 hover:shadow-xl hover:shadow-fg/15 transition-shadow"
        >
          <img
            src={item.image}
            alt={item.name}
            class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/70 via-35% to-black/5"></div>
          <div class="relative p-6 md:p-7 text-white">
            <p class="text-accent text-[11px] font-semibold tracking-wider mb-1.5 uppercase">{item.role}</p>
            <h3 class="text-xl md:text-[22px] font-bold mb-3 leading-tight">{item.name}</h3>
            <p class="text-white/85 text-[13px] leading-[1.75] line-clamp-3">{item.quote}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 flex justify-center reveal">
      <a
        href={fullPagePath}
        class="inline-flex items-center gap-2.5 text-[16px] md:text-[17px] font-semibold text-primary hover:text-primary-light transition-colors"
      >
        {t('leaders.readMore')}
        <span class="rtl:rotate-180 text-[18px]">→</span>
      </a>
    </div>
  </div>
</section>
