---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedDate?: string;
  tags?: string[];
  schema?: object | null;
}

const SITE = 'https://dralqefari.com';
const {
  lang,
  title,
  description,
  image,
  canonicalPath,
  type = 'website',
  noindex = false,
  publishedDate,
  tags,
  schema,
} = Astro.props;

const t = useTranslations(lang);

const finalTitle = title ?? t('meta.title');
const finalDescription = description ?? t('meta.description');
const finalImage = image ?? `${SITE}/images/profile.webp`;

// Build hreflang URLs from the canonical path. The path is treated as the
// "language-neutral" path; for English we prepend /en, for Arabic we use it as-is.
const rawPath = canonicalPath ?? (lang === 'ar' ? '/' : '/en/');
const arPath = rawPath.startsWith('/en/')
  ? (rawPath === '/en/' ? '/' : rawPath.replace(/^\/en\//, '/'))
  : rawPath;
const enPath = arPath === '/' ? '/en/' : `/en${arPath}`;
const canonicalUrl = `${SITE}${lang === 'ar' ? arPath : enPath}`;
const arUrl = `${SITE}${arPath}`;
const enUrl = `${SITE}${enPath}`;

const siteName = lang === 'ar' ? 'د. عبدالله القفاري' : 'Dr. Abdullah Alqefari';

const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dr. Abdullah Alqefari',
  alternateName: 'د. عبدالله القفاري',
  jobTitle: 'University Professor & Coach',
  url: SITE,
  image: `${SITE}/images/profile.webp`,
  sameAs: [
    'https://instagram.com/DrAlqefari',
    'https://x.com/DrAlqefari',
    'https://tiktok.com/@DrAlqefari',
    'https://www.youtube.com/@alqefari',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Riyadh',
    addressRegion: 'Riyadh',
    addressCountry: 'SA',
  },
};

const finalSchema = schema === undefined ? defaultSchema : schema;
---
<!-- Primary meta -->
<title>{finalTitle}</title>
<meta name="description" content={finalDescription} />
<meta name="author" content="Dr. Abdullah Alqefari" />
<meta http-equiv="content-language" content={lang === 'ar' ? 'ar-SA' : 'en-US'} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Geo targeting (Riyadh, Saudi Arabia) -->
<meta name="geo.region" content="SA-01" />
<meta name="geo.placename" content="Riyadh, Saudi Arabia" />
<meta name="geo.position" content="24.7136;46.6753" />
<meta name="ICBM" content="24.7136, 46.6753" />

<!-- Canonical & hreflang -->
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="ar" href={arUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={arUrl} />

<!-- Open Graph -->
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={lang === 'ar' ? 'ar_SA' : 'en_US'} />
<meta property="og:locale:alternate" content={lang === 'ar' ? 'en_US' : 'ar_SA'} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={finalImage} />
<meta property="og:image:alt" content={finalTitle} />

{type === 'article' && publishedDate && (
  <meta property="article:published_time" content={publishedDate} />
)}
{type === 'article' && tags && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@DrAlqefari" />
<meta name="twitter:creator" content="@DrAlqefari" />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={finalImage} />
<meta name="twitter:image:alt" content={finalTitle} />

<!-- Favicon suite -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#880209" />
<meta name="msapplication-TileColor" content="#880209" />

<!-- JSON-LD Schema -->
{finalSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
)}
