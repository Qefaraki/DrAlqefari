---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);

const leaders = [
  {
    key: 'gates',
    name: t('leaders.gates.name'),
    role: t('leaders.gates.role'),
    quote: t('leaders.gates.quote'),
    source: t('leaders.gates.source'),
    image: '/images/leaders/bill-gates.webp',
  },
  {
    key: 'schmidt',
    name: t('leaders.schmidt.name'),
    role: t('leaders.schmidt.role'),
    quote: t('leaders.schmidt.quote'),
    source: t('leaders.schmidt.source'),
    image: '/images/leaders/eric-schmidt.webp',
  },
  {
    key: 'bezos',
    name: t('leaders.bezos.name'),
    role: t('leaders.bezos.role'),
    quote: t('leaders.bezos.quote'),
    source: t('leaders.bezos.source'),
    image: '/images/leaders/jeff-bezos.webp',
  },
  {
    key: 'welch',
    name: t('leaders.welch.name'),
    role: t('leaders.welch.role'),
    quote: t('leaders.welch.quote'),
    source: t('leaders.welch.source'),
    image: '/images/leaders/jack-welch.webp',
  },
  {
    key: 'lafley',
    name: t('leaders.lafley.name'),
    role: t('leaders.lafley.role'),
    quote: t('leaders.lafley.quote'),
    source: t('leaders.lafley.source'),
    image: '/images/leaders/ag-lafley.webp',
  },
  {
    key: 'oprah',
    name: t('leaders.oprah.name'),
    role: t('leaders.oprah.role'),
    quote: t('leaders.oprah.quote'),
    source: t('leaders.oprah.source'),
    image: '/images/leaders/oprah-winfrey.webp',
  },
  {
    key: 'gawande',
    name: t('leaders.gawande.name'),
    role: t('leaders.gawande.role'),
    quote: t('leaders.gawande.quote'),
    source: t('leaders.gawande.source'),
    image: '/images/leaders/atul-gawande.webp',
  },
];

const stanford = {
  name: t('leaders.stanford.name'),
  role: t('leaders.stanford.role'),
  quote: t('leaders.stanford.quote'),
  source: t('leaders.stanford.source'),
};

const references = [
  t('leaders.references.1'),
  t('leaders.references.2'),
  t('leaders.references.3'),
  t('leaders.references.4'),
  t('leaders.references.5'),
];
---

<section class="border-t border-border/60">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-7">
      {leaders.map((item) => (
        <article class="reveal relative rounded-2xl overflow-hidden bg-fg/90 min-h-[560px] md:min-h-[620px] flex flex-col justify-end shadow-lg shadow-fg/10">
          <img
            src={item.image}
            alt={item.name}
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 via-30% to-black/10"></div>
          <div class="relative p-7 md:p-9 text-white">
            <p class="text-accent text-[11px] font-semibold tracking-wider mb-2 uppercase">{item.role}</p>
            <h3 class="text-2xl md:text-[26px] font-bold mb-4 leading-tight">{item.name}</h3>
            <blockquote class="text-[14px] md:text-[15px] leading-[1.85] text-white/90">
              {item.quote}
            </blockquote>
            {item.source && (
              <p class="text-white/50 text-[11px] mt-4">— {item.source}</p>
            )}
          </div>
        </article>
      ))}

      <!-- Stanford study card — no portrait, stat-focused -->
      <article class="reveal relative rounded-2xl overflow-hidden min-h-[560px] md:min-h-[620px] flex flex-col justify-end shadow-lg shadow-fg/10 md:col-span-2 bg-gradient-to-br from-primary via-[#6a0206] to-[#3d0103]">
        <div class="absolute inset-0 flex items-start justify-center pt-14 md:pt-16">
          <div class="text-center">
            <p class="text-white/90 text-[11px] font-semibold tracking-[0.25em] uppercase mb-4">Stanford GSB · 2013</p>
            <p class="text-white text-[88px] md:text-[120px] font-black leading-none tabular-nums">⅔</p>
            <p class="text-white/70 text-[12px] md:text-[13px] font-medium tracking-wider uppercase mt-3 max-w-xs mx-auto px-4">
              {lang === 'ar' ? 'من الرؤساء التنفيذيين بلا مستشار خارجي' : 'of CEOs work without an outside advisor'}
            </p>
          </div>
        </div>
        <div class="absolute inset-x-0 bottom-0 h-[55%] bg-gradient-to-t from-black/80 via-black/50 to-transparent"></div>
        <div class="relative p-7 md:p-10 text-white max-w-3xl">
          <p class="text-accent text-[11px] font-semibold tracking-wider mb-2 uppercase">{stanford.role}</p>
          <h3 class="text-2xl md:text-[26px] font-bold mb-4 leading-tight">{stanford.name}</h3>
          <blockquote class="text-[14px] md:text-[15px] leading-[1.85] text-white/90">
            {stanford.quote}
          </blockquote>
        </div>
      </article>
    </div>

    <!-- Conclusion -->
    <div class="mt-16 md:mt-20 reveal">
      <h2 class="text-xl md:text-2xl font-bold text-fg mb-5">{t('leaders.conclusion.title')}</h2>
      <p class="text-fg-light leading-[1.95] text-[16px]">{t('leaders.conclusion.body')}</p>
    </div>

    <!-- Dr. Alqefari signature quote -->
    <div class="mt-14 reveal bg-accent/[0.06] border border-accent/15 rounded-3xl p-8 md:p-10">
      <p class="text-fg/90 leading-[2] text-[16px] md:text-[17px] italic">
        {t('leaders.signature.quote')}
      </p>
      <p class="text-primary font-bold text-[14px] mt-5">— {t('leaders.signature.name')}</p>
    </div>

    <!-- References -->
    <div class="mt-14 reveal">
      <h2 class="text-base md:text-lg font-bold text-fg mb-5">{t('leaders.references.title')}</h2>
      <ul class="space-y-2">
        {references.map((ref) => (
          <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-muted/60 mt-2.5 shrink-0"></div>
            <p class="text-muted text-[13px] leading-[1.8]">{ref}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
