---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);

const leaders = [
  {
    key: 'gates',
    name: t('leaders.gates.name'),
    role: t('leaders.gates.role'),
    bio: t('leaders.gates.bio'),
    quote: t('leaders.gates.quote'),
    source: t('leaders.gates.source'),
    image: '/images/leaders/bill-gates.webp',
  },
  {
    key: 'schmidt',
    name: t('leaders.schmidt.name'),
    role: t('leaders.schmidt.role'),
    bio: t('leaders.schmidt.bio'),
    quote: t('leaders.schmidt.quote'),
    source: t('leaders.schmidt.source'),
    image: '/images/leaders/eric-schmidt.webp',
  },
  {
    key: 'bezos',
    name: t('leaders.bezos.name'),
    role: t('leaders.bezos.role'),
    bio: t('leaders.bezos.bio'),
    quote: t('leaders.bezos.quote'),
    source: t('leaders.bezos.source'),
    image: '/images/leaders/jeff-bezos.webp',
  },
  {
    key: 'welch',
    name: t('leaders.welch.name'),
    role: t('leaders.welch.role'),
    bio: t('leaders.welch.bio'),
    quote: t('leaders.welch.quote'),
    source: t('leaders.welch.source'),
    image: '/images/leaders/jack-welch.webp',
  },
  {
    key: 'lafley',
    name: t('leaders.lafley.name'),
    role: t('leaders.lafley.role'),
    bio: t('leaders.lafley.bio'),
    quote: t('leaders.lafley.quote'),
    source: t('leaders.lafley.source'),
    image: '/images/leaders/ag-lafley.webp',
  },
  {
    key: 'oprah',
    name: t('leaders.oprah.name'),
    role: t('leaders.oprah.role'),
    bio: t('leaders.oprah.bio'),
    quote: t('leaders.oprah.quote'),
    source: t('leaders.oprah.source'),
    image: '/images/leaders/oprah-winfrey.webp',
  },
  {
    key: 'gawande',
    name: t('leaders.gawande.name'),
    role: t('leaders.gawande.role'),
    bio: t('leaders.gawande.bio'),
    quote: t('leaders.gawande.quote'),
    source: t('leaders.gawande.source'),
    image: '/images/leaders/atul-gawande.webp',
  },
  {
    key: 'stanford',
    name: t('leaders.stanford.name'),
    role: t('leaders.stanford.role'),
    bio: t('leaders.stanford.bio'),
    quote: t('leaders.stanford.quote'),
    source: t('leaders.stanford.source'),
    image: '',
  },
];

const references = [
  t('leaders.references.1'),
  t('leaders.references.2'),
  t('leaders.references.3'),
  t('leaders.references.4'),
  t('leaders.references.5'),
];
---

<section class="border-t border-border/60">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12">
      {leaders.map((item) => (
        <article class="reveal flex flex-col bg-bg-card rounded-3xl p-7 md:p-8 shadow-sm shadow-fg/[0.03] border border-border/40">
          <div class="flex items-start gap-4 mb-5">
            {item.image ? (
              <img
                src={item.image}
                alt={item.name}
                width="64"
                height="64"
                class="w-16 h-16 rounded-full object-cover bg-bg-warm border border-border/40 shrink-0"
                loading="lazy"
              />
            ) : (
              <div class="w-16 h-16 rounded-full bg-primary/[0.08] border border-primary/15 shrink-0 flex items-center justify-center">
                <svg class="w-7 h-7 text-primary/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                </svg>
              </div>
            )}
            <div class="min-w-0 pt-1">
              <h3 class="font-bold text-fg text-[16px] leading-tight">{item.name}</h3>
              <p class="text-accent text-[12px] font-semibold leading-snug mt-1">{item.role}</p>
            </div>
          </div>

          <p class="text-muted text-[13px] leading-[1.85] mb-4">{item.bio}</p>

          <blockquote class="text-fg-light leading-[1.9] text-[15px] border-s-2 border-accent/40 ps-4 italic">
            {item.quote}
          </blockquote>

          {item.source && (
            <p class="text-muted text-[11px] mt-4">— {item.source}</p>
          )}
        </article>
      ))}
    </div>

    <!-- Conclusion -->
    <div class="mt-16 md:mt-20 reveal">
      <h2 class="text-xl md:text-2xl font-bold text-fg mb-5">{t('leaders.conclusion.title')}</h2>
      <p class="text-fg-light leading-[1.95] text-[16px]">{t('leaders.conclusion.body')}</p>
    </div>

    <!-- Dr. Alqefari signature quote -->
    <div class="mt-14 reveal bg-accent/[0.06] border border-accent/15 rounded-3xl p-8 md:p-10">
      <p class="text-fg/90 leading-[2] text-[16px] md:text-[17px] italic">
        {t('leaders.signature.quote')}
      </p>
      <p class="text-primary font-bold text-[14px] mt-5">— {t('leaders.signature.name')}</p>
    </div>

    <!-- References -->
    <div class="mt-14 reveal">
      <h2 class="text-base md:text-lg font-bold text-fg mb-5">{t('leaders.references.title')}</h2>
      <ul class="space-y-2">
        {references.map((ref) => (
          <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-muted/60 mt-2.5 shrink-0"></div>
            <p class="text-muted text-[13px] leading-[1.8]">{ref}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
